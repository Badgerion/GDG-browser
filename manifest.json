{
  "manifest_version": 3,
  "name": "Graphical Density Grounding- Browser Execution Layer",
  "version": "0.2.0",
  "description": "Spatial text representation of web pages for AI agent consumption- by Artiqal",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "nativeMessaging",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["renderer.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Graphical Density"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
